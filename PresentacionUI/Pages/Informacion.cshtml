@page "{id:int}" 
@model PresentacionUI.Pages.InformacionModel
@{
    
}
<div class="container mt-5">
    <div class="card shadow-sm border-0 mx-auto" style="max-width: 800px;">
        <div class="row g-0 align-items-start">
            
            <div class="col-md-5">
                <img src="@Model.Doctores.Foto" 
                     class="img-fluid rounded-start" 
                     alt="Foto de doctor"
                     style="width: 100%; height: 100%; object-fit: cover; min-height: 400px;">
            </div>

            <div class="col-md-7">
                <div class="card-body p-4">
                    <h5 class="text-primary text-uppercase fw-bold mb-1" style="letter-spacing: 1px;">
                        @(Model.Doctores.Especialidad.Nombre_especialidad)
                    </h5>
                    
                    <h1 class="display-6 fw-bold text-dark">
                        Dr. @Model.Doctores.Nombre @Model.Doctores.Apellido
                    </h1>
                    <hr class="my-4" style="width: 50px; border: 2px solid #0d6efd; opacity: 1;">
                    <span class="text-black fw-bold" style="letter-spacing: 1px;">
                        Estudios:
                    </span>
                    <h5 class="text-primary  text-uppercase fw-bold" style="letter-spacing: 1px;">
                        @(Model.Doctores.AlmaMater)
                    </h5>
                    <span class="text-black fw-bold" style="letter-spacing: 1px;">
                        Horario de atención:
                    </span>
                    <span class="text-muted">
                        <br />
                        @Model.Doctores.HoraEntrada.ToString(@"hh\:mm") AM
                        <br />
                        @Model.Doctores.HoraSalida.ToString(@"hh\:mm") PM
                        <br />
                    </span>
                    <span class="text-black fw-bold" style="letter-spacing: 1px;">
                        Perfil Profesional:
                    </span>
                    <p class="text-body" style="letter-spacing: 1px">
                        @Model.Doctores.Perfil
                      </p>
                    
                    <div class="mt-4">
                        <a href="/Doctores" class="btn btn-outline-dark rounded-pill px-4">
                            <i class="bi bi-arrow-left me-2"></i>Regresar
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>