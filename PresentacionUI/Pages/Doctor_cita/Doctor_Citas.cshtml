@page
@model PresentacionUI.Pages.Docto_cita.Doctor_CitasModel
@{
    ViewData["Title"] = "Lista de Citas";

}
<div class="container mt-4">
    <h2 class="mb-4 text-center">Historial de Citas</h2>
    
    
    @if (Model.Citas.Count == 0)
    {
        <div class="alert alert-info">
            No hay citas registradas.
        </div>
    }
    else{
       
            <table class="table table-striped table-bordered">
                <thead class="table-primary">
                    <tr>
                        <th>Fecha</th>
                        <th>Hora</th>
                        <th>Paciente</th>
                        <th>Especialidad</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cita in Model.Citas)
                    {
                        <tr>
                            <td>@cita.Fecha</td>
                            <td>@cita.Hora</td>
                            <td>
                                @cita.Paciente.Nombre @cita.Paciente.Apellido
                            </td>
                            <td>
                            <form method="post">
                                    <input type="hidden" name="idCita" value="@cita.Id_Citas" />
                                    <select name="estado"
                                            class="form-select"
                                            onchange="this.form.submit()">

                                        <option value="Pendiente"
                                                selected="@(cita.Estado == cita.Estado)">
                                            Pendiente
                                        </option>
                                        <option value="Completada" 
                                                selected="@(cita.Estado == "Completada")">
                                            Completada
                                        </option>
                                        <option value="No Asistida" 
                                                selected="@(cita.Estado == "No Asistida")">
                                            No Asistida
                                        </option>
                                    </select>
                                </form>
                            </td>
                            <td>@cita.Motivo</td>
                        </tr>
                    }
                </tbody>
            </table>
      }
        </div>
            <div style="height: calc(100vh - 250px);">
    </div>
</div>
